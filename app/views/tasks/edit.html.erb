<div class="container mt-5">
  <h1>Edit task</h1>

  <%= form_with model: @task, url: task_path(@task), method: :patch, local: true do |f| %>
    <div class="mb-3">
      <%= f.label :title, class: "form-label" %>
      <%= f.text_field :title, class: "form-control" %>
    </div>

    <div class="mb-3">
      <%= f.label :details, class: "form-label" %>
      <%= f.text_area :details, class: "form-control" %>
    </div>

    <div class="form-check mb-3">
      <%= f.check_box :completed, class: "form-check-input", id: "completed" %>
      <%= f.label :completed, "Completed", class: "form-check-label", for: "completed" %>
    </div>

    <%= f.submit "Update task", class: "btn btn-primary" %>
  <% end %>

  <%= link_to "Back to list", tasks_path, class: "btn btn-secondary mt-3" %>
</div>
