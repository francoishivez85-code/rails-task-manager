<div class="container mt-5">
  <h1>New task</h1>

  <%= form_with model: @task, url: tasks_path, local: true do |f| %>
    <div class="mb-3">
      <%= f.label :title, class: "form-label" %>
      <%= f.text_field :title, class: "form-control" %>
    </div>

    <div class="mb-3">
      <%= f.label :details, class: "form-label" %>
      <%= f.text_area :details, class: "form-control" %>
    </div>

    <%= f.submit "Create task", class: "btn btn-primary" %>
  <% end %>

  <%= link_to "Back to list", tasks_path, class: "btn btn-secondary mt-3" %>
</div>
